# Application Config
APP_ENV=development
APP_NAME=agent-router

# Logfire
# LOGFIRE_TOKEN=your_token_here

# PostgreSQL Database
POSTGRES_USER=agent_user
POSTGRES_PASSWORD=agent_pass
POSTGRES_DB=agent_router
# host.docker.internal routes Docker traffic out to the Windows Host (which runs docker-compose port 5432)
# This allows both 'uv run' and 'docker run' to hit the exact same database.
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_SSL_ENABLED=disable

# pgAdmin (Docker)
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# Gemini Model
# GEMINI_API_KEY=your_gemini_api_key_here
